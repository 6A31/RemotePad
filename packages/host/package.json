{
  "name": "@remotepad/host",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build -w @remotepad/protocol && tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "test:security": "tsx --test test/security.test.ts test/ip-filter.test.ts",
    "change-password": "tsx scripts/change-password.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@remotepad/protocol": "*",
    "bcrypt": "^5.1.1",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "koffi": "^3.0.2",
    "node-screenshots": "^0.2.1",
    "sharp": "^0.33.5",
    "systray2": "^2.1.4",
    "to-ico": "^1.1.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.1",
    "@types/ws": "^8.18.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "ws": "^8.18.1"
  }
}
